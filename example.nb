Cell[CellGroupData[{

Cell[TextData[{
 "Mass sum rules (",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalOmega]", "B"], "-"], TraditionalForm]],
  ExpressionUUID->"ed08ac90-e07f-6244-a32b-40ece4aeacd7"],
 ")"
}], "Subsection",
 CellChangeTimes->{{3.96186187051857*^9, 3.9618618772531567`*^9}, {
   3.9624681599284897`*^9, 3.962468161196415*^9}, {3.962992495198431*^9, 
