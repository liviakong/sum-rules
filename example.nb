Cell[TextData[{
 "Use ",
 Cell[BoxData[
  RowBox[{"printSRs", "[", 
   RowBox[{"system", ",", " ", 
    RowBox[{
     RowBox[{"ampType", " ", "OR", " ", "amp2Type"}], " ", "->", " ", 
     RowBox[{"{", "_", "}"}]}], ",", " ", 
    RowBox[{"b", " ", "->", " ", "_"}], ",", " ", 
    RowBox[{"other", " ", "opts"}]}], "]"}]], "InlineCode",ExpressionUUID->
  "cac224b9-4c35-de49-a16f-1e2692954308"],
 " to extract the ASR/A2SR matrices for breaking orders b. This function will \
also add a formatted amplitude vector to your system variable which you can \
access via ",
 Cell[BoxData[
  RowBox[{"system", "[", 
   RowBox[{"[", "\"\<Amp vector\>\"", "]"}], "]"}]], "InlineCode",
  ExpressionUUID->"d35e5caa-40a8-6e4f-bce2-668942d4fe2b"],
 ".\n\nNote:\n- If you use a/s (or \[CapitalDelta]/\[CapitalSigma]) \
amplitudes, ",
 Cell[BoxData[
  RowBox[{"system", "[", 
   RowBox[{"[", "\"\<Amp vector\>\"", "]"}], "]"}]], "InlineCode",
  ExpressionUUID->"d8057fc2-cc44-5d44-bdb8-7844c253985a"],
 " returns ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"a", " ", "vector"}], ",", " ", 
    RowBox[{"s", " ", "vector"}]}], "}"}]], "InlineCode",ExpressionUUID->
  "34c7a144-eabe-b846-b8c0-5f762f0bc127"],
 ". If you use A amplitudes, ",
 Cell[BoxData[
  RowBox[{"system", "[", 
   RowBox[{"[", "\"\<Amp vector\>\"", "]"}], "]"}]], "InlineCode",
  ExpressionUUID->"942ed6c6-00e7-6c48-ba98-523f2abc5c73"],
 " returns ",
 Cell[BoxData[
  RowBox[{"A", " ", "vector"}]], "InlineCode",ExpressionUUID->
  "f580e87d-3af3-f045-a384-f824ceab1be5"],
 ". Make sure to use a (s) vectors with even (odd) b SR matrices.\n- Only one \
of ampType and amp2Type should be specified, and only one of ASRs or A2SRs \
can be printed/extracted with this function.\n- If b is set to a single \
number, the function outputs a single matrix. If b is set to All or a range, \
the function outputs a list of matrices corresponding to those b values.\n- \
Set ",
 Cell[BoxData[
  RowBox[{"showSRs", " ", "->", " ", "False"}]], "InlineCode",ExpressionUUID->
  "71b914a7-ffcf-9049-9e33-a8be309a2c6c"],
 " to suppress the printing output."
}], "Text",
