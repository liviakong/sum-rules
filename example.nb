Cell[CellGroupData[{

Cell[TextData[{
 "Define the physical system (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["D", "0"], " ", "->", " ", 
    RowBox[{
     SuperscriptBox["P", "+"], 
     SuperscriptBox["P", "-"]}]}], TraditionalForm]],ExpressionUUID->
  "da97e790-372f-0040-b343-fe1888710f72"],
 ")"
}], "Subsection",
 CellChangeTimes->{{3.96186187051857*^9, 3.9618618772531567`*^9}, {
