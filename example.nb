Cell[TextData[{
 "The physical input mode of ",
 Cell[BoxData[
 "generateSRs"], "InlineCode",ExpressionUUID->
  "963eae36-339c-854d-8df5-47b9b34f5a02"],
 " is enabled by setting ",
 Cell[BoxData[
  RowBox[{"phys", " ", "->", " ", "True"}]], "InlineCode",ExpressionUUID->
  "37aaa934-6512-5444-9f9a-8aa7e6fffc96"],
 ". In this mode, the function takes in the physical multiplets in the \
external states and the factors in the Hamiltonian as inputs: ",
 Cell[BoxData[
  RowBox[{"generateSRs", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"in", " ", "multiplets"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"H", " ", "factors"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"out", " ", "multiplets"}], "}"}], ",", " ", 
    RowBox[{"phys", " ", "->", " ", "True"}]}], "]"}]], "InlineCode",
  ExpressionUUID->"7fc927d8-12e0-aa46-93ea-a27624e5439f"],
 ".\n\nRun the generateSRs function for the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["D", "0"], " ", "->", " ", 
    RowBox[{
     SuperscriptBox["P", "+"], 
     SuperscriptBox["P", "-"]}]}], TraditionalForm]],ExpressionUUID->
  "9bcf0621-e35d-aa4c-b826-c9bb015b0bc9"],
 " system:"
}], "Text",
