Cell[TextData[{
 "List the multiplets in the in state, Hamiltonian, and out state and set \
phys to True: ",
 Cell[BoxData[
  RowBox[{"generateSRs", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"in", " ", "multiplets"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"H", " ", "multiplet"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"out", " ", "multiplets"}], "}"}], ",", " ", 
    RowBox[{"phys", " ", "->", " ", "True"}]}], "]"}]], "InlineCode",
  ExpressionUUID->"7fc927d8-12e0-aa46-93ea-a27624e5439f"],
 "."
}], "Text",
