 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Import", " ", "the", " ", "Mathematica", " ", "package"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SetDirectory", "[", 
     RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Get", "[", "\"\<FlaSR.m\>\"", "]"}], ";"}], 
