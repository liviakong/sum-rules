Cell[TextData[{
 "List the representations in the in state, Hamiltonian, and out state using ",
 Cell[BoxData[
  RowBox[{"generateASRs", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"in", " ", "reps"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"H", " ", "rep"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"out", " ", "reps"}], "}"}]}], "]"}]], "InlineCode",
  ExpressionUUID->"4e648208-962f-964e-966c-2c5d7bbe1f3b"],
