Cell[TextData[{
 "To view the sum rules between integrated observables instead, set ",
 Cell[BoxData[
  RowBox[{"obs", " ", "->", " ", "\"\<Int\>\""}]], "InlineCode",
  ExpressionUUID->"d66fb117-4994-b148-80d8-fe75b2869169"],
 " in the ",
 Cell[BoxData[
 "generateSRs"], "InlineCode",ExpressionUUID->
  "bf691a3b-d109-e949-b1cd-1367e8268357"],
 " function. This will combine amplitudes corresponding to the same channel \
and handle combinatorial factors for identical particles from the final-state \
phase-space integrals.\n\nTo show only the sum rules part of the full output, \
use the ",
 Cell[BoxData[
  RowBox[{"printSRs", "[", 
   RowBox[{"system", ",", " ", 
    RowBox[{"ampType", " ", "->", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"a", ",", "s"}], "}"}], "/", 
        RowBox[{"{", "A", "}"}]}], " ", "OR", " ", "amp2Type"}], " ", "->", 
      " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[CapitalDelta]", ",", "\[CapitalSigma]"}], "}"}], "/", 
       RowBox[{"{", "A", "}"}]}]}]}], ",", "..."}], "]"}]], "InlineCode",
  ExpressionUUID->"c19eaf76-128c-1446-836f-6a33c9a58aa7"],
 " function to print either ASRs or A2SRs. Between the differential and \
integrated cases, only the A2SRs are different, so we print the A2SRs here in \
expanded form."
}], "Text",
 CellChangeTimes->{{3.9572795724097958`*^9, 3.9572795810493298`*^9}, {
  3.9572796733786983`*^9, 3.9572797470475464`*^9}, {3.957279894376028*^9, 
  3.957280134006321*^9}, {3.957283416834299*^9, 3.9572837577545147`*^9}, {
  3.957283972959978*^9, 
  3.9572839735157757`*^9}},ExpressionUUID->"2a80bc76-83b5-2748-a66e-\
a6bc64414670"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"system", "=", 
   RowBox[{"generateSRs", "[", 
    RowBox[{
     RowBox[{"{", "Dq", "}"}], ",", 
     RowBox[{"{", "HDPP", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"Pp", ",", "Pm", ",", "Pm"}], "}"}], ",", 
     RowBox[{"phys", "->", "True"}], ",", 
     RowBox[{"obs", "->", "\"\<Int\>\""}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"printSRs", "[", 
   RowBox[{"system", ",", 
    RowBox[{"amp2Type", "->", 
     RowBox[{"{", "A", "}"}]}], ",", 
    RowBox[{"expandSRs", "->", "True"}]}], "]"}], ";"}]}], "Input",
