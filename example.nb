Cell[CellGroupData[{

Cell["Option 2: Define a physical system", "Subsection",
 CellChangeTimes->{{3.96186187051857*^9, 3.9618618772531567`*^9}, {
  3.9624681599284897`*^9, 3.962468161196415*^9}, {3.962992495198431*^9, 
