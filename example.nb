Cell[CellGroupData[{

Cell["View results", "Section",
 CellChangeTimes->{{3.964877531777622*^9, 3.964877533048332*^9}, {
  3.9654263451356087`*^9, 3.965426345476589*^9}, {3.969222748926613*^9, 
