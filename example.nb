(",
 Cell[BoxData[
  RowBox[{"ampType", " ", "->", " ", 
   RowBox[{"{", "m", "}"}]}]], "InlineCode",ExpressionUUID->
  "255d650c-c662-4d4b-aa9e-8ff7aa3292b3"],
