Cell[CellGroupData[{

Cell["Example: Matrix operations", "Subsection",
 CellChangeTimes->{{3.96186187051857*^9, 3.9618618772531567`*^9}, {
  3.9624681599284897`*^9, 3.962468161196415*^9}, {3.962992495198431*^9, 
  3.962992538601721*^9}, {3.965425659396185*^9, 3.965425659530676*^9}, {
  3.9708382065725784`*^9, 
  3.970838216753868*^9}},ExpressionUUID->"56926b81-7c36-1e48-8a99-\
ce90a4dd5d79"],

Cell[TextData[{
 "Use ",
 Cell[BoxData[
  RowBox[{"printSRs", "[", 
   RowBox[{"system", ",", " ", 
    RowBox[{
     RowBox[{"ampType", " ", "OR", " ", "amp2Type"}], " ", "->", " ", 
     RowBox[{"{", "_", "}"}]}], ",", " ", 
    RowBox[{"b", " ", "->", " ", "_"}], ",", " ", 
    RowBox[{"other", " ", "opts"}]}], "]"}]], "InlineCode",ExpressionUUID->
  "092a6102-6d21-2a4c-84f1-0070667bbc14"],
 " to extract the ASR/A2SR matrices for breaking orders b. This function will \
also add a formatted amplitude vector to your system variable which you can \
access via ",
 Cell[BoxData[
  RowBox[{"system", "[", 
   RowBox[{"[", "\"\<Amp vector\>\"", "]"}], "]"}]], "InlineCode",
  ExpressionUUID->"94165609-8277-6342-849c-9c4432582292"],
 ".\n\nNote:\n- If you use a/s (or \[CapitalDelta]/\[CapitalSigma]) \
amplitudes, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"system", "[", 
    RowBox[{"[", "\"\<Amp vector\>\"", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", " ", "vector"}], ",", " ", 
     RowBox[{"s", " ", "vector"}]}], "}"}]}]], "InlineCode",ExpressionUUID->
  "db4ab6d3-c514-c84e-bd74-e8b682480f1b"],
 ". If you use A amplitudes, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"system", "[", 
    RowBox[{"[", "\"\<Amp vector\>\"", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"A", " ", "vector"}]}]], "InlineCode",ExpressionUUID->
  "af5d5b77-939e-c940-bb53-aa875eedd54d"],
 ". Make sure to use a (s) vectors with even (odd) b SR matrices.\n- Only one \
of ampType and amp2Type should be specified, and only one type of SRs can be \
printed/extracted with this function.\n- If b is set to a single number, the \
function outputs a single matrix. If b is set to All or a range, the function \
outputs a list of matrices corresponding to those b values.\n- Set ",
 Cell[BoxData[
  RowBox[{"showSRs", " ", "->", " ", "False"}]], "InlineCode",ExpressionUUID->
  "15b2eb95-6ec6-e14d-ae8d-197ea6293957"],
 " to suppress the printing output."
}], "Text",
 CellChangeTimes->{{3.9669587454157104`*^9, 3.966958813429323*^9}, {
   3.966959172783947*^9, 3.9669592341061535`*^9}, {3.970784658507269*^9, 
   3.9707846588961773`*^9}, {3.9757692877353554`*^9, 
