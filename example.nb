Cell[TextData[{
 "To format and view the output, use the ",
 Cell[BoxData[
  RowBox[{"printSystem", "[", 
   RowBox[{"system", ",", " ", 
    RowBox[{"ampType", " ", "->", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "s"}], "}"}], " ", "OR", " ", 
      RowBox[{"{", "A", "}"}]}]}], ",", " ", 
    RowBox[{"amp2Type", " ", "->", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[CapitalDelta]", ",", "\[CapitalSigma]"}], "}"}], " ", "OR", 
      " ", 
      RowBox[{"{", "A", "}"}]}]}], ",", "..."}], "]"}]], "InlineCode",
  ExpressionUUID->"1045ac2f-c0ed-7842-a34c-96564b809a0f"],
