334399f0221c"],

Cell[TextData[{
 "Amplitudes of the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", " ", "->", " ", "h"}], TraditionalForm]],ExpressionUUID->
  "a36ae351-d4aa-e643-b2d4-58aa42277854"],
 ", where h is a hadron, can be interpreted as hadron masses. The program can \
be used to derive mass sum rules by first generating amplitude sum rules and \
then reformatting the results in terms of masses.\n\nHere we generate sum \
rules for an abstract system with a U-spin structure matching that of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["\[CapitalOmega]", "B"], "-"], " ", "->", " ", 
    SuperscriptBox[
     SubscriptBox["\[CapitalOmega]", "B"], "-"]}], TraditionalForm]],
  ExpressionUUID->"368f7aac-340b-f342-bbcd-701f6ec53650"],
 ". We view its amplitude table using the ",
 Cell[BoxData[
  RowBox[{"printAmps", "[", 
   RowBox[{"system", ",", "..."}], "]"}]], "InlineCode",ExpressionUUID->
  "56acb6f3-419d-3644-a6f8-e8001b6a2188"],
 " function."
}], "Text",
 CellChangeTimes->{{3.9669587454157104`*^9, 3.966958813429323*^9}, {
   3.966959172783947*^9, 3.9669592341061535`*^9}, {3.970784658507269*^9, 
