Cell[TextData[{
 "To print, use the syntax ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"printSystem", "[", 
    RowBox[{"system", ",", " ", 
     RowBox[{"ampType", " ", "->", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "s"}], "}"}], " ", "OR", " ", 
       RowBox[{"{", "A", "}"}]}]}], ",", " ", 
     RowBox[{"amp2Type", " ", "->", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[CapitalDelta]", ",", "\[CapitalSigma]"}], "}"}], " ", "OR",
        " ", 
       RowBox[{"{", "A", "}"}]}]}]}], "]"}], ";"}]], "InlineCode",
  ExpressionUUID->"4b3fdfa1-384e-614b-9147-665c9d384fc0"],
 "\n\nPrinting options: showReps (True|False), showAmps (True|False), \
showASRs (True|False), showA2SRs (True|False), expandSRs (True|False), CKM \
(True|False), b (All|Real|{min,max,increment=1}).\n\nNote:\n- a/s definitions \
change depending on the system and are provided alongside the amplitude \
table.\n- ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["A", "_"], TraditionalForm]],ExpressionUUID->
  "27a5bb92-9a10-214f-891d-57852bfc0049"],
 " represents the U-spin conjugate amplitude to A, not to be confused with \
the CP conjugate.\n- ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["A", "2"], TraditionalForm]],ExpressionUUID->
  "5a255469-084d-6540-8d86-229597836126"],
 " in the A2SRs outputs below should be interpreted as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"|", "A", 
    SuperscriptBox["|", "2"]}], TraditionalForm]],ExpressionUUID->
  "5d1d2445-d030-3242-a14f-a3badf2abe35"],
 "."
}], "Text",
 CellChangeTimes->{{3.9669587454157104`*^9, 3.966958813429323*^9}, {
