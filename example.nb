Cell[TextData[{
 "We want to index the amplitudes with the names of particles rather than the \
names of processes (e.g., ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalDelta]", "-"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5a5cba2d-672c-b440-a2a8-369e9de80acb"],
 " instead of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalDelta]", "-"], " ", "->", " ", 
    SuperscriptBox["\[CapitalDelta]", "-"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "16e23a4e-a4b3-f24f-9617-d7b3ef7b28c0"],
 ") or any of the other labeling conventions. To do this, we must add a \
column of custom labels to the amplitudes table using the ",
 Cell[BoxData[
  RowBox[{"labelAmps", "[", 
   RowBox[{"system", ",", " ", "colName", ",", " ", "labels", ",", "..."}], 
   "]"}]], "InlineCode",ExpressionUUID->
  "52c6f32f-1a99-fb41-9cee-0a1037fba2e7"],
 " function, which takes in the system, the name of the new custom column, \
and a list of labels for the amplitudes in the order they appear in the \
amplitude table.\n\nThere is also an ",
 Cell[BoxData[
 "unlabelAmps"], "InlineCode",ExpressionUUID->
  "630fed84-f967-1446-8d9c-8bda380dfb78"],
 " function if needed."
}], "Text",
 CellChangeTimes->{{3.9572820701919174`*^9, 3.9572820921504*^9}, {
