  3.978728707744011*^9, 
  3.978728713455042*^9}},ExpressionUUID->"b2816cc7-43f9-2e40-bb49-\
cf7596829baa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"D0", "=", 
   RowBox[{"{", "\"\<\!\(\*SuperscriptBox[\(D\), \(0\)]\)\>\"", "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"H1", "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["f", 
      RowBox[{"1", ",", "1"}]], ",", 
     SubscriptBox["f", 
      RowBox[{"1", ",", "0"}]], ",", 
     SubscriptBox["f", 
      RowBox[{"1", ",", 
       RowBox[{"-", "1"}]}]]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"H2", "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["f", 
      RowBox[{
       RowBox[{"1", "/", "2"}], ",", 
       RowBox[{"1", "/", "2"}]}]], ",", 
     SubscriptBox["f", 
      RowBox[{
       RowBox[{"1", "/", "2"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}]}]]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pp", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(K\), \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[\(\[Pi]\), \(+\)]\)\>\""}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pm", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(\[Pi]\), \(-\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[\(K\), \(-\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"P0", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(K\), \(0\)]\)\>\"", 
     ",", "\"\<\!\(\*SubscriptBox[\(\[Eta]\), \(u\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[OverscriptBox[\(K\), \(_\)], \
\(0\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"P0st", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(K\), \(*\(0\)\)]\)\>\"", 
     ",", "\"\<\!\(\*SubscriptBox[\(\[Phi]\), \(u\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[OverscriptBox[\(K\), \(_\)], \
\(*\(0\)\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B0bar", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SubsuperscriptBox[OverscriptBox[\(B\), \(_\)], \(s\), \
\(0\)]\)\>\"", 
     ",", "\"\<\!\(\*SubsuperscriptBox[OverscriptBox[\(B\), \(_\)], \(d\), \
\(0\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"OBm", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(\[CapitalDelta]\), \(-\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SuperscriptBox[\(\[CapitalSigma]\), \
\(*\)], \(-\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SuperscriptBox[\(\[CapitalXi]\), \(*\)], \
\(-\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[\(\[CapitalOmega]\), \(-\)]\)\>\""}], 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"OBp", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[OverscriptBox[\(\[CapitalOmega]\), \
\(_\)], \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SuperscriptBox[OverscriptBox[\(\
\[CapitalXi]\), \(_\)], \(*\)], \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SuperscriptBox[OverscriptBox[\(\
\[CapitalSigma]\), \(_\)], \(*\)], \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[OverscriptBox[\(\[CapitalDelta]\), \
\(_\)], \(+\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Cb", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[SubscriptBox[\(\[CapitalLambda]\), \
\(c\)], \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SubscriptBox[\(\[CapitalXi]\), \(c\)], \
\(+\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Lb", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<p\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[\(\[CapitalSigma]\), \(+\)]\)\>\""}], 
    "}"}]}], ";"}]}], "Input",
