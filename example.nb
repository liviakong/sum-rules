  3.957277946898382*^9}, {3.957278039661049*^9, 3.9572780684396057`*^9}, {
  3.9572783340881577`*^9, 
  3.957278335286169*^9}},ExpressionUUID->"b2816cc7-43f9-2e40-bb49-\
cf7596829baa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"D0", "=", 
   RowBox[{"{", "\"\<\!\(\*SuperscriptBox[\(D\), \(0\)]\)\>\"", "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"HDPP", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["\[Lambda]", "2"]}], ",", 
     RowBox[{
      SqrtBox["2"], "*", "\[Lambda]"}], ",", 
     RowBox[{"-", "1"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pp", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(K\), \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[\(\[Pi]\), \(+\)]\)\>\""}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Pm", "=", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*SuperscriptBox[\(\[Pi]\), \(-\)]\)\>\"", 
      ",", "\"\<\!\(\*SuperscriptBox[\(K\), \(-\)]\)\>\""}], "}"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"For", " ", "convenience"}], ",", " ", 
    RowBox[{
    "we", " ", "define", " ", "all", " ", "the", " ", "multiplets", " ", 
     "for", " ", "the", " ", "subsequent", " ", "examples", " ", "here", " ", 
     "as", " ", "well"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Dq", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(D\), \(-\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SubscriptBox[\(D\), \(s\)], \
\(-\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B0bar", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SubsuperscriptBox[OverscriptBox[\(B\), \(_\)], \(s\), \
\(0\)]\)\>\"", 
     ",", "\"\<\!\(\*SubsuperscriptBox[OverscriptBox[\(B\), \(_\)], \(d\), \
\(0\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"OBm", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(\[CapitalDelta]\), \(-\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SuperscriptBox[\(\[CapitalSigma]\), \
\(*\)], \(-\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SuperscriptBox[\(\[CapitalXi]\), \(*\)], \
\(-\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[\(\[CapitalOmega]\), \(-\)]\)\>\""}], 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"OBp", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[OverscriptBox[\(\[CapitalOmega]\), \
\(_\)], \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SuperscriptBox[OverscriptBox[\(\
\[CapitalXi]\), \(_\)], \(*\)], \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SuperscriptBox[OverscriptBox[\(\
\[CapitalSigma]\), \(_\)], \(*\)], \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[OverscriptBox[\(\[CapitalDelta]\), \
\(_\)], \(+\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"P0", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(K\), \(0\)]\)\>\"", 
     ",", "\"\<\!\(\*SubscriptBox[\(\[Eta]\), \(u\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[OverscriptBox[\(K\), \(_\)], \
\(0\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"P0st", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[\(K\), \(*\(0\)\)]\)\>\"", 
     ",", "\"\<\!\(\*SubscriptBox[\(\[Phi]\), \(u\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[OverscriptBox[\(K\), \(_\)], \
\(*\(0\)\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Cb", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\!\(\*SuperscriptBox[SubscriptBox[\(\[CapitalLambda]\), \
\(c\)], \(+\)]\)\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[SubscriptBox[\(\[CapitalXi]\), \(c\)], \
\(+\)]\)\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Lb", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<p\>\"", 
     ",", "\"\<\!\(\*SuperscriptBox[\(\[CapitalSigma]\), \(+\)]\)\>\""}], 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"HBDOO", "=", 
    RowBox[{"{", 
     RowBox[{
      SuperscriptBox["\[CapitalAlpha]\[Lambda]", "3"], ",", 
      SuperscriptBox["\[CapitalAlpha]\[Lambda]", "2"]}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "To", " ", "prevent", " ", "potential", " ", "naming", " ", "conflicts", " ",
      "later"}], ",", " ", 
    RowBox[{
    "we", " ", "enter", " ", "the", " ", "Wolfenstein", " ", "parameter", " ",
      "A", " ", "as", " ", "the", " ", "CapitalAlpha", " ", "symbol"}]}], " ",
    "*)"}]}], "\[IndentingNewLine]"}], "Input",
