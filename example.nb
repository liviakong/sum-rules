Cell[CellGroupData[{

Cell[BoxData["\<\"generateSRs[in,h,out] finds all amplitudes, amplitude sum \
rules (ASRs), and amplitude-squared sum rules (A2SRs) for a given \
system.\"\>"], "Print",
 CellChangeTimes->{
  3.9774183938431625`*^9, 3.978618321595522*^9, 3.981041986169277*^9, {
   3.981582643032791*^9, 3.9534618934862823`*^9}, 3.9574550140265217`*^9, 
   3.957463935576315*^9},
 CellLabel->
  "During evaluation of \
In[6]:=",ExpressionUUID->"cb48a1c8-fe55-4247-8508-dfd9e9b7495a"],

Cell[BoxData["\<\"Arguments:\\nin (List): Contains U-spins (Real) OR particle \
multiplets (List of Strings) in the incoming state.\\nh (List): Contains \
U-spins (Real) OR coefficients (List of Symbols) in the Hamiltonian.\\nout \
(List): Contains U-spins (Real) OR particle multiplets (List of Strings) in \
the outgoing state.\\n\\nOptions:\\nphys (True|False): Indicates whether \
function arguments contain U-spins (False) or particle multiplets/CKM factors \
(True). Default: phys->False.\\nobs (\\\"Diff\\\"|\\\"Int\\\"): Indicates \
whether A2SRs should be treated as the sum rules between differential \
(\\\"Diff\\\") or integrated (\\\"Int\\\") observables. Only in effect when \
phys->True. Default: obs->\\\"Diff\\\".\\n\\nReturns:\\nsystem (Association): \
All information about the system's representations, amplitudes, ASRs, and \
A2SRs. Keys and values:\\n- \\\"Irreps\\\" (List): Inputted U-spin \
representations (List of Reals) in {{in reps}, {H rep}, {out reps}} \
format.\\n- \\\"Multiplets\\\" (List): Inputted multiplets (List of Strings) \
and factors (List of Symbols) in {{in multiplets}, {H factors}, {out \
multiplets}} format for physical systems. Empty for group-theoretic \
systems.\\n- \\\"n doublets\\\" (Real): Number of would-be doublets.\\n- \
\\\"p factor\\\" (Real): (-1)^p factor for defining a/s-type amplitudes.\\n- \
\\\"n amps\\\" (Real): Number of amplitudes in the system.\\n- \\\"Amplitudes\
\\\" (List): Contains an Association for each amplitude pair in the system. \
Keys and values:\\n\\t- \\\"Processes\\\" (List): Contains physical processes \
(String) for an amplitude and its U-spin conjugate. Only available for \
physical systems.\\n\\t- \\\"QNs\\\" (List): Contains m quantum number labels \
(String), where m is the third component of U-spin, for an amplitude and its \
U-spin conjugate.\\n\\t- \\\"n-tuples\\\" (List): Contains n-tuple labels \
(String) for an amplitude and its U-spin conjugate. n-tuples represent \
amplitudes as comma-separated tuples of substrings, where each substring is \
comprised of '-'s and '+'s and encodes the u and m QNs of a component of a \
participating multiplet. Signs are inverted for initial state and Hamiltonian \
components.\\n\\t- \\\"Coords\\\" (String): Coordinate (String) for an \
amplitude pair in the lattice used to derive sum rules.\\n\\t- \\\"Binary \
indices\\\" (List): Contains indices (Real), written in base 10, for an \
amplitude and its U-spin conjugate. Indices are derived by converting the \
n-tuples into binary numbers through '-' <-> 0 and '+' <-> 1 and removing \
commas.\\n\\t- \\\"mu\\\" (Real): mu-factor for the coordinate in the lattice \
used to derive sum rules.\\n\\t- \\\"CG\\\" (Real): Clebsch-Gordan \
coefficient from symmetrization for systems without doublets. Equal to 1 for \
all amplitudes for a system with at least one doublet.\\n\\t- \\\"CKM\\\" \
(List): Contains weak interaction factors (Real) from the Hamiltonian. Only \
appears for physical systems.\\n- \\\"n ASRs\\\" (List): Contains the number \
of amplitude sum rules (Real) at each order of breaking.\\n- \\\"ASRs\\\" \
(List): Contains matrices of amplitude sum rule coefficients (Real) \
corresponding to each order of breaking.\\n- \\\"Unique amp pairs\\\" (List): \
Contains indices (Real) of amplitude pairs corresponding to unique channels \
after integration. Only appears for physical systems with \
obs->\\\"Int\\\".\\n- \\\"n A2SRs\\\" (List): Contains the number of \
amplitude-squared sum rules (Real) at each order of breaking.\\n- \\\"A2SRs\\\
\" (List): Contains matrices of amplitude-squared sum rule coefficients \
(Real) corresponding to each order of breaking.\\n- \\\"SR extract\\\" \
(List): Contains sum rule coefficient matrices at the selected b. If only \
ampType (amp2Type) is specified, contains only ASR (A2SR) coefficients. If \
both ampType and amp2Type are specified, contains A2SR coefficients. \
Initialized to None by generateSRs and redefined after running \
printSystem.\\n- \\\"Amp vector\\\" (List): Either is a vector of formatted \
A-type amplitudes (Symbols) or contains formatted vectors for a- and s-type \
amplitudes (List of Symbols) for the system. Initialized to None by \
generateSRs and redefined after running printSystem.\"\>"], "Print",
 CellChangeTimes->{
  3.9774183938431625`*^9, 3.978618321595522*^9, 3.981041986169277*^9, {
   3.981582643032791*^9, 3.9534618934862823`*^9}, 3.9574550140265217`*^9, 
   3.957463935576315*^9},
 CellLabel->
  "During evaluation of \
In[6]:=",ExpressionUUID->"c0911a9b-901a-0f47-ae28-ecd7f7f74eb6"]
}, Open  ]]
}, Open  ]]
}, Closed]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Generate a U-spin system and view its sum rules", "Section",
 CellChangeTimes->{{3.9654256206031303`*^9, 3.9570990622953186`*^9}, {
  3.9886475300135384`*^9, 3.9886475313487186`*^9}, {3.988647570115261*^9, 
  3.988647575058605*^9}, {3.9886478111826344`*^9, 
  3.988647828846697*^9}},ExpressionUUID->"1c92be0e-8333-0744-adaf-\
414f3ed0c714"],

Cell[CellGroupData[{

Cell[TextData[{
 "Define the U-spin system (",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", " ", "->", " ", 
    RowBox[{
     FractionBox["1", "2"], "\[CircleTimes]", 
     FractionBox["1", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "6d78b607-7861-ff46-9cbe-2c022a24348e"],
 ")"
}], "Subsection",
 CellChangeTimes->{{3.96186187051857*^9, 3.9618618772531567`*^9}, {
  3.9624681599284897`*^9, 3.962468161196415*^9}, {3.962992495198431*^9, 
  3.962992504292259*^9}, {3.965425658271948*^9, 3.9654256583746834`*^9}, {
  3.9886476540991917`*^9, 
  3.957278515442133*^9}},ExpressionUUID->"233f1844-b5c9-4c47-8c79-\
0b57e41b4586"],

Cell[TextData[{
 "To generate all amplitudes, amplitude sum rules, and amplitude-squared sum \
rules for a U-spin system, use the ",
 Cell[BoxData[
  RowBox[{"generateSRs", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"in", " ", "reps"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"H", " ", "rep"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"out", " ", "reps"}], "}"}], ",", "..."}], "]"}]], "InlineCode",
  ExpressionUUID->"3af10041-97ea-604f-9829-38dc362ae40d"],
 " function. In the default abstract input mode, this function requires lists \
of the representations in the in state, Hamiltonian, and out state, with the \
dots indicating additional input options which can be set via ",
 Cell[BoxData[
  RowBox[{"option", " ", "->", " ", "value"}]], "InlineCode",ExpressionUUID->
  "7c8bc6f5-3b5f-454a-acba-11a9d8a3a940"],
 ".\n\n",
 Cell[BoxData[
 "generateSRs"], "InlineCode",ExpressionUUID->
  "5fb35041-d28b-0947-be55-73517c94c1cb"],
 " options: ",
 Cell[BoxData[
 "phys"], "InlineCode",ExpressionUUID->"312dd702-924a-9141-a057-35a2a4b70b88"],
 " (",
 Cell[BoxData[
  RowBox[{"True", "|", "False"}]], "InlineCode",ExpressionUUID->
  "5ce82d7f-17f2-b144-9957-1311177444c9"],
 "), ",
 Cell[BoxData[
 "obs"], "InlineCode",ExpressionUUID->"f8c498d1-80ab-f040-af79-10ff365e7b5a"],
 " (",
 Cell[BoxData[
  RowBox[{"\"\<Diff\>\"", "|", "\"\<Int\>\""}]], "InlineCode",ExpressionUUID->
  "6400fd9f-c2b0-e34f-a23f-a3a472d5767c"],
 ").\n\nWe generate sum rules for a system with a singlet in the in state, a \
triplet Hamiltonian, and two doublets in the final state:"
}], "Text",
 CellChangeTimes->{{3.9669588523886223`*^9, 3.9669589761933613`*^9}, {
  3.966959090322937*^9, 3.9669590915133934`*^9}, {3.970837944954443*^9, 
  3.9708379511588345`*^9}, {3.97872867048374*^9, 3.978728696967516*^9}, {
  3.978728825307476*^9, 3.957276742091633*^9}, {3.95727677650119*^9, 
  3.957276792059412*^9}, {3.957277304302767*^9, 3.9572773324069767`*^9}, {
  3.957277390604025*^9, 3.9572775024598618`*^9}, {3.957277816458803*^9, 
  3.9572778328549976`*^9}, {3.957288527200819*^9, 3.9572885858329964`*^9}, {
  3.957288647312586*^9, 3.957288787044359*^9}, {3.9572888305392513`*^9, 
  3.95728885955867*^9}},ExpressionUUID->"24bc30dc-2f04-984a-b974-\
a03b2cd4ff6e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"system", "=", 
   RowBox[{"generateSRs", "[", 
    RowBox[{
     RowBox[{"{", "0", "}"}], ",", 
     RowBox[{"{", "1", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"1", "/", "2"}], ",", 
       RowBox[{"1", "/", "2"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
