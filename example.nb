Cell[CellGroupData[{

Cell["Import files and initialize the Python session", "Section",
 CellChangeTimes->{{3.9654254746474895`*^9, 3.965425486673561*^9}, {
  3.965425568920616*^9, 
  3.96542556923048*^9}},ExpressionUUID->"4aa9d8e1-d61b-3d45-a0f7-\
7c3ef4c60912"],

Cell[TextData[{
 "Download ",
 Cell[BoxData[
  RowBox[{"FlaSR", ".", "m"}]], "InlineCode",ExpressionUUID->
  "f6196251-c270-3a46-94bc-c42978f90f65"],
 " and ",
 Cell[BoxData[
  RowBox[{"FlaSR", ".", "py"}]], "InlineCode",ExpressionUUID->
  "7168bcd6-e029-7a47-9a45-5ca6976af98e"],
 " and ensure both files are in the same directory as this file (",
 Cell[BoxData[
  RowBox[{"example", ".", "nb"}]], "InlineCode",ExpressionUUID->
  "2edb64bd-7047-2e46-b7f8-ee41bfb2d209"],
 "). Then, run this cell to load the Mathematica package and the Python file, \
which is used to perform part of the calculations. It is best to run the ",
 Cell[BoxData[
  RowBox[{"Quit", "[", "]"}]], "InlineCode",ExpressionUUID->
  "ded2ed99-890d-864f-8215-2d3caf050db7"],
 " function above and to rerun this initialization cell every time you \
restart the Mathematica kernel.\n\nIf you experience any problems starting \
the Python session, please refer to our Python help guide on GitHub: \
https://github.com/liviakong/sum-rules/blob/main/docs/python_help.md"
}], "Text",
 CellChangeTimes->{{3.970833433495434*^9, 3.970833456755224*^9}, {
  3.970837978975851*^9, 3.9708380083901596`*^9}, {3.9774180669558296`*^9, 
